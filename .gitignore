# IST-Core v1 .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
.venv311/
venv/
ENV/

# Python test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment / secrets
environment
.env
*.env

# Backup (local only, not in git)
backup/

# Logs / temp
logs/
tmp/
*.log

# Data stores (dev containers)
postgres_storage/
qdrant_storage/
.langgraph_data/
.langgraph_api/
.web_server.pid

# LangGraph checkpoint（QA_AGENT_SQLITE_PATH，含 WAL/SHM 同伴文件）
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite.wal
*.sqlite.shm

# OS
.DS_Store
Thumbs.db

# Runtime（CLAUDE.md：logs / conversation_history / large_tool_results / users）
runtime/

# 历史：仓库根下同名目录（与 runtime/ 子目录并存时仍生效）
large_tool_results/
conversation_history/

# Memory subsystem: 用户私有偏好 / 工作记忆 / dream 锁不进 git；
# AGENTS.md 是团队级项目指令，git 跟踪（用 ! 反选必须先按子路径忽略，
# 不能直接 ignore "memory/" 整体——目录级 ignore 优先于反选规则）
memory/working/
memory/long_term/
memory/reviews/
memory/.dream/
/knowledge/

# Agent workspace（运行时：上传 / 产出 / 缺陷缓存；仅跟踪 .gitkeep 占位）
workspace/*
!workspace/*/
workspace/*/*
!workspace/*/.gitkeep

# 本地开发笔记（不进版本库）
测试评审skill开发tips.md
docs/context_reuse_vs_cc_haha.md
docs/prompt_gap_vs_cc_haha.md

# Claude
.claude/
ssh_users.json

# 框架镜像层（framework_sync 从跳转机增量拉取的实证用例 + 能力源；量大、可重建，不进库）
# derived/（idiom 库等挖掘产物）需跟踪，单独豁免
knowledge/framework/mirror/
# 跳转机 smoke_test xlsx 全量 zip 备份（本地留存，可重建）
knowledge/framework/backups/
!knowledge/framework/derived/
reference/
.cursor/
environment.bak*
