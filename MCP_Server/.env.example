# APV MCP Server 配置文件
# 复制此文件为 .env 并修改对应值
# 注意: .env 中的值会覆盖系统环境变量

# APV 设备 SSH/Telnet 凭据
APV_USERNAME=admin
APV_PASSWORD=admin
APV_ENABLE_PASSWORD=

# APV 设备 REST API 凭据
APV_RESTAPI_USERNAME=admin
APV_RESTAPI_PASSWORD=admin

# Linux 服务器 SSH 凭据
LINUX_SSH_USERNAME=root
LINUX_SSH_PASSWORD=click1
# LINUX_SSH_KEY=/path/to/private_key

# HTTP/SSE 监听地址（仅 --http / --sse 模式生效）
MCP_HOST=127.0.0.1
MCP_PORT=8000
