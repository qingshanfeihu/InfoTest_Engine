# =============================================================================
# InfoTest Engine 本地配置
# 复制为 environment（无扩展名）后填入下方取值。已在 .gitignore，勿提交。
#   cp environment.example environment
# =============================================================================


# =============================================================================
# 一、API 凭证（按厂商分组）
# =============================================================================

# ---- DashScope / 阿里云百炼 ------------------------------------------------
# 用途：qwen 系列 chat（KMS 分类、memory dream、可选评审主链路）
# 申请：https://bailian.console.aliyun.com/?tab=model#/api-key
DASHSCOPE_API_KEY=
# 同一把 Key 的别名（与 DASHSCOPE_API_KEY 二选一）
# BAILIAN_API_KEY=
# 可选：自定义兼容端点（一般留空走默认 OpenAI 兼容地址）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# ---- DeepSeek -------------------------------------------------------------
# 用途：deepseek-v4-pro 评审主链路、deepseek-v4-flash explore / haiku tier
# 申请：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com


# ---- MinerU --------------------------------------------------------------
# 用途：main/mineru_batch_export.py PDF / docx → markdown
MINERU_TOKEN=


# ---- LangSmith 观测（默认关闭；调试时临时打开，trace 含 prompt 全文）-------
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=infotest_engine


# =============================================================================
# 二、模型路由（IST-Core 评审主链路 + 三档 tier）
#
# 设计：dashscope / deepseek 两个 provider 平等并列。启用方式 = 把目标 provider
# 那一组取消注释，另一组整组保留注释作为参考。tier 是按任务复杂度分档的
# 模型映射，opus = 评审 / 推理，sonnet = QA / 文档问答，haiku = explore / 路由。
# =============================================================================

# ---- 选项 A：DashScope qwen ------------------------------------------------
IST_LLM_PROVIDER=dashscope
IST_MODEL=qwen-plus
IST_REVIEW_MODEL=qwen-plus
IST_OPUS_MODEL=qwen3.6-plus
IST_SONNET_MODEL=qwen-plus
IST_HAIKU_MODEL=qwen-turbo
IST_ALLOWED_MODELS=qwen-plus,qwen3.6-plus,qwen-turbo


# ---- 选项 B：DeepSeek （启用时把上面 A 整组注释）---------------------------
# DeepSeek 优势（相对 qwen3.6-plus）：
#   - tool_choice="required" 原生支持 → SubAgent / Pydantic 结构化输出可靠
#   - 自动 prompt cache（前缀匹配，命中价 1/50）
#   - reasoning_content 字段名跟 qwen 一致 → ChatOpenAIWithReasoning 直接复用
# 痛点：deepseek-reasoner 不支持 function calling，主 agent 不可用。
#
# IST_LLM_PROVIDER=deepseek
# IST_MODEL=deepseek-v4-pro
# IST_REVIEW_MODEL=deepseek-v4-pro
# IST_OPUS_MODEL=deepseek-v4-pro
# IST_SONNET_MODEL=deepseek-v4-pro
# IST_HAIKU_MODEL=deepseek-v4-flash
# IST_ALLOWED_MODELS=deepseek-v4-pro,deepseek-v4-flash,deepseek-chat


# ---- 评审通用 -------------------------------------------------------------
IST_REVIEW_DEPTH=standard               # quick | standard | deep
# IST_INTERRUPT_ON=web_bug_search,qa_exec   # 调试时强制人工 interrupt 的工具
# IST_DEBUG_PAYLOAD=1                       # 打印 deepseek payload 大小 + reasoning_content 注入数


# =============================================================================
# 三、运行时持久化（Checkpoint / Memory store）
# =============================================================================

# LangGraph checkpoint（TUI 用 AsyncSqliteSaver，需 pip install aiosqlite）
# 提示：如果是升级用户，可将本地现有的 qa_agent.sqlite 重命名为 ist_core.sqlite 以恢复历史 Session 状态。
IST_SQLITE_PATH=./ist_core.sqlite

# 可选：Postgres checkpoint（不设时用 IST_SQLITE_PATH，再降级 InMemorySaver）
# IST_POSTGRES_CHECKPOINT_DSN=postgresql://ultra_agent:ultra_agent@localhost:6543/ultra_agent
IST_POSTGRES_CHECKPOINT_SETUP=1

# Memory store backend（空 → InMemory；sqlite:/// 或 postgresql:// 持久化）
# IST_MEMORY_STORE_DSN=sqlite:///./memory_store.sqlite


# =============================================================================
# 四、记忆子系统（main/ist_core/memory/）
# =============================================================================
IST_MEMORY_ENABLED=1
# IST_MEMORY_ROOT=<repo>/memory                 # 默认 repo/memory
IST_MEMORY_DISTILL_EVERY_N=30                   # 每 N 轮触发 fork agent distill
IST_MEMORY_L2_TOPK=3
IST_MEMORY_STALE_DAYS=30
# IST_MEMORY_DISABLE_LLM=0                      # 1 = 仅规则抽取，不调 fork agent / dream

IST_DREAM_ENABLED=1
IST_DREAM_LOOKBACK_DAYS=7
IST_DREAM_PRUNE_DAYS=7
IST_DREAM_MIN_SESSIONS=5

FOOTPRINT_ENABLED=1                             # CLI footprint 知识树（autodream 增强）


# =============================================================================
# 五、产品测试平台 PostgreSQL（任务状态 / trace；可选）
# =============================================================================
# 可选 PostgreSQL（任务状态 / trace）；按 IST_POSTGRES_DSN 连接。
# 注：旧 `main.qa_agent.runtime.postgres_admin` 已随包迁移移除；schema 请用平台自带迁移工具初始化。
IST_POSTGRES_HOST=localhost
IST_POSTGRES_PORT=6543
IST_POSTGRES_DB=ultra_agent
IST_POSTGRES_USER=ultra_agent
IST_POSTGRES_PASSWORD=ultra_agent
IST_POSTGRES_DSN=postgresql://ultra_agent:ultra_agent@localhost:6543/ultra_agent


# =============================================================================
# 六、缺陷库抓取（Bugzilla / 禅道 / WebVPN）
# =============================================================================
# DEFECT_BACKEND 控制批量索引入口数据来源：
#   fixtures — 读 knowledge/fixtures/bugs_*.json（CI / 离线默认）
#   live     — 读 knowledge/defect_cleaned/{backend}/*.json
DEFECT_BACKEND=fixtures
DEFECT_ON_DEMAND_ENABLED=true
DEFECT_CACHE_TTL_HOURS=24
# 模糊前缀（BUG-12345 / 纯数字）按下表顺序逐个 backend 试，首个有效详情页落库
DEFECT_FETCH_AUTO_CHAIN=zentao,bugzilla
# DEFECT_FETCH_DISPLAY=1                        # 强制 headful，调试 / 演示用

# WebVPN 门户登录（抓取 Bugzilla / 禅道 必需）
PORTAL_LOGIN_USER=
PORTAL_LOGIN_PASS=
# BUGZILLA_LOGIN_USER= / BUGZILLA_LOGIN_PASS= / ZENDAO_LOGIN_USER= / ZENDAO_LOGIN_PASS=  覆盖 PORTAL_*
# PORTAL_LOGIN_URL=                              # 入口默认够用，企业内网 IP 变更时覆盖

# 真实地址（WebVPN 代理失败时 fallback）
BUGZILLA_BASE_URL=http://bugzilla.arraynetworks.com.cn/bugzilla
ZENTAO_BASE_URL=https://plm.infosec.com.cn

# Playwright
PLAYWRIGHT_HEADLESS=1
PLAYWRIGHT_STATE_DIR=knowledge/.intermediate/defect_raw/_state
# CAPTCHA_OCR_RETRY=10
# LOGIN_RETRY=5

# 首次：python -m main.ingest.defect_fetch --backend {bugzilla|zentao} --refresh-login


# =============================================================================
# 七、KMS / MinerU 管线（运行时由 /kms 子命令设置；下面是 override 示例）
# =============================================================================
# KMS_PRODUCT_FILES=                             # 逗号分隔白名单
# KMS_OUTPUT_BUCKET=qa                           # product | qa
# MINERU_BATCH_SIZE=30
# KMS_UPDATE_TIMEOUT_SEC=7200
# KMS_LOG_POLL_INTERVAL_SEC=2
# NO_PROGRESS=1                                  # 非 TTY 环境禁用进度条
