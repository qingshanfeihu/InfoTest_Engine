/* IST-Core TUI v3 styles 창 FullscreenLayout 챌짯채쨩쨌
   (FullscreenLayout.tsx:361 ScrollBox + 414 bottom slot)찾 */

Screen {
    layout: vertical;
}

#root {
    height: 1fr;
    layout: vertical;
}

/* 채쨍쨩챈쨋챈짱챈쨉챦쩌책혻챈쨩징책짤채쩍챌짤쨘챕쨈챦쩌챔짧책짢챈쨩책째챈챈째챦쩌stickyScroll 챌짯채쨩쨌챦쩌*/
#transcript {
    height: 1fr;
    padding: 0 1;
}

/* bottom slot: 책쨘책짰챕짬책쨘짝챦쩌책
 prompt / completion / footer */
#bottom-slot {
    height: auto;
    layout: vertical;
}

/* PromptInput: 창챔짙쨍 ``> `` + 책챌쩍책
챈혻챦쩌챈혻 box / 챈혻챈짢짧챌쨘쩔찾
   PromptInput 챔짧책쨌짹 DEFAULT_CSS 책쨌짼챔짰쩐 height=1 + transparent 챔챈짱챦쩌챔쩔챕채쨍챕챔짝책책혻챔짠책찾 */

/* 챌짢챈쨌챔쩐책
짜챈쨋챈짱챦쩌 backgroundColor='userMessageBackground'챦쩌챦쩌
   책
짢책짰쩍채쨍책짹챔챈짱챔짼챦쩌책쨘책 user vs assistant 챈쨋챈짱 */
InlineMessage.ist-human-input {
    width: 1fr;
    background: $surface-darken-1;
    color: $text;
    padding: 0 1;
    margin: 1 0;
}

/* Slash 챔징짜책
짢책챕챈징챦쩌챕쨩챔짰짚 height=0챦쩌챔쩐책
짜 / 챈쨋책책째 1챦쩌*/
#slash-completion {
    height: 0;
    background: $boost;
    color: $accent;
    padding: 0 1;
}
#slash-completion.visible {
    height: 1;
}

/* 2 챔징 footer챦쩌status + hint챦쩌챦쩌PromptInputFooter 챌짯채쨩쨌 */
#footer {
    height: 2;
}

/* Inline message 챈쨍짼챈챦쩌Messages flat list 챕짙챈혻쩌챦쩌*/
InlineMessage {
    height: auto;
    width: 1fr;
}

ToolOutputBlock {
    height: auto;
    width: 1fr;
    margin-bottom: 1;
}

CompletionLine {
    height: 1;
    width: 1fr;
}

StreamingMarkdown {
    height: auto;
    width: 1fr;
    margin: 0 0 1 0;
}
