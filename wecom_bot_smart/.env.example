# ============================================================
# 企业微信智能机器人 — WebSocket 长连接模式
# 在项目根 environment 文件中配置
# ============================================================

# --- 智能机器人（必填，企微后台「智能机器人 → API 模式 → 使用长连接」提供）---
WECOM_SMART_BOT_ID=your_bot_id_here
WECOM_SMART_SECRET=your_secret_here
WECOM_SMART_GATEWAY_URL=wss://openws.work.weixin.qq.com

# --- 文档/智能表格工具（可选，用于自动生成测试报告）---
# 在企微后台「智能机器人 → 编辑 → 可使用权限」授权后，
# 点击「streamableHTTP URL」复制，填入下方。
# 有效期 7 天，到期需重新授权。
# WECOM_SMART_MCP_DOC_URL=https://...

# --- 服务配置（可选）---
# WECOM_SMART_IST_TIMEOUT=600   # IST-Core 单次调用最长等待（秒）
